{
  "name": "@hesed/mcp-server",
  "version": "0.1.0",
  "description": "MCP server plugin — exposes all CLI commands as MCP tools",
  "author": "Hesed",
  "bin": {
    "mcp-server": "./bin/run.js"
  },
  "bugs": "https://github.com/hesedcasa/mcp-server/issues",
  "dependencies": {
    "@hesed/permission": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@oclif/core": "^4",
    "@toon-format/toon": "^2.3.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^5",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10",
    "@types/node": "^25",
    "chai": "^6",
    "chai-as-promised": "^8.0.2",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "prettier": "^3.8.1",
    "shx": "^0.4.0",
    "ts-node": "^10",
    "ts-prune": "^0.10.3",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/hesedcasa/mcp-server",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "mcp-server",
    "dirname": "mcp-server",
    "commands": "./dist/commands",
    "topics": {}
  },
  "repository": "hesedcasa/mcp-server",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md",
    "find-deadcode": "ts-prune --ignore '(run|default)'",
    "format": "eslint --cache --fix --quiet . && prettier --write --cache .",
    "pre-commit": "npm run format && npm run find-deadcode"
  },
  "types": "dist/index.d.ts"
}
